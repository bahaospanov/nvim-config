@@ -189,6 +189,15 @@ vim.diagnostic.config {
 
 vim.keymap.set('n', '<leader>q', vim.diagnostic.setloclist, { desc = 'Open diagnostic [Q]uickfix list' })
 
+vim.keymap.set('n', '<leader>yp', function()
+  local abs = vim.fn.expand '%:p'
+  local root = vim.fn.systemlist('git rev-parse --show-toplevel')[1] or ''
+  local rel = root ~= '' and abs:gsub('^' .. vim.pesc(root) .. '/', '') or abs
+  local path = '@' .. rel .. ':' .. vim.fn.line '.'
+  vim.fn.setreg('+', path)
+  print('Copied: ' .. path)
+end, { desc = '[Y]ank file [p]ath with line number' })
+
 -- Exit terminal mode in the builtin terminal with a shortcut that is a bit easier
 -- for people to discover. Otherwise, you normally need to press <C-\><C-n>, which
 -- is not what someone will guess without a bit more experience.
