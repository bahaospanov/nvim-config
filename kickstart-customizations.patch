+      -- Original: statusline.setup { use_icons = vim.g.have_nerd_font }
+      statusline.setup {
+        use_icons = vim.g.have_nerd_font,
+        content = {
+          active = function()
+            local mode, mode_hl = statusline.section_mode { trunc_width = 120 }
+            local diagnostics = statusline.section_diagnostics { trunc_width = 75 }
+            local location = '%2l:%-2v'
+            local head = vim.b.gitsigns_head or ''
+            local gstatus = vim.b.gitsigns_status or ''
+            local git = (head ~= '' and (' ' .. head) or '') .. (gstatus ~= '' and (' ' .. gstatus) or '')
+            return statusline.combine_groups {
+              { hl = mode_hl, strings = { mode } },
+              { hl = 'MiniStatuslineDevinfo', strings = { git, diagnostics } },
+              '%=',
+              { hl = 'MiniStatuslineFileinfo', strings = { location } },
+            }
+          end,
+        },
+      }
+
+      -- Winbar shows file path (skip floating windows)
+      vim.api.nvim_create_autocmd({ 'BufEnter' }, {
+        callback = function()
+          if vim.api.nvim_win_get_config(0).relative ~= '' then return end
+          vim.wo.winbar = '%{fnamemodify(expand("%"), ":~:.")}'
+        end,
+      })
 
